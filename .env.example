# Copy this file to .env and fill in values. Never commit .env.
#
# Usage:
#   cp .env.example .env
#   # edit .env with real values
#   docker-compose up

# Admin API bearer token for /reload and /drain endpoints.
# Leave empty to disable auth (default).
AEGIS_API_TOKEN=your_api_token_here

# Grafana admin credentials. (default settings are admin/admin)
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
